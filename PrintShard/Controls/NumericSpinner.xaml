<UserControl x:Class="PrintShard.Controls.NumericSpinner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="22">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBox x:Name="ValueTextBox"
                 Grid.Column="0"
                 Text="{Binding Value, RelativeSource={RelativeSource AncestorType=UserControl}, 
                        UpdateSourceTrigger=LostFocus, StringFormat='{}{0:F1}'}"
                 VerticalContentAlignment="Center"
                 Padding="2,0"/>

        <Grid Grid.Column="1" Width="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <RepeatButton x:Name="UpButton"
                          Grid.Row="0"
                          Click="UpButton_Click"
                          Focusable="False"
                          FontSize="8"
                          FontFamily="Segoe UI Symbol"
                          Padding="0"
                          BorderThickness="1,1,1,0">
                <Path Data="M 0,4 L 4,0 L 8,4 Z" 
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                      Width="8" Height="5"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </RepeatButton>

            <RepeatButton x:Name="DownButton"
                          Grid.Row="1"
                          Click="DownButton_Click"
                          Focusable="False"
                          FontSize="8"
                          FontFamily="Segoe UI Symbol"
                          Padding="0"
                          BorderThickness="1,0,1,1">
                <Path Data="M 0,0 L 4,4 L 8,0 Z" 
                      Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RepeatButton}}"
                      Width="8" Height="5"
                      Stretch="Uniform"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>
            </RepeatButton>
        </Grid>
    </Grid>
</UserControl>
