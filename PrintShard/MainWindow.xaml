<Window x:Class="PrintShard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PrintShard.Controls"
        xmlns:models="clr-namespace:PrintShard.Models"
        xmlns:conv="clr-namespace:PrintShard.Converters"
        Title="{Binding WindowTitle}"
        Height="700" Width="1050" MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BoolToVisibilityConverter  x:Key="BoolToVisibility"/>
        <conv:EnumToBoolConverter        x:Key="EnumToBool"/>
        <conv:NullToVisibilityConverter  x:Key="NullToVisibility"/>
        <conv:ColorStringToColorConverter x:Key="ColorStringToColor"/>
    </Window.Resources>

    <!-- ── Keyboard Shortcuts ──────────────────────────────────────────────── -->
    <Window.InputBindings>
        <KeyBinding Key="O"        Modifiers="Ctrl"       Command="{Binding OpenFileCommand}"/>
        <KeyBinding Key="P"        Modifiers="Ctrl"       Command="{Binding PrintCommand}"/>
        <KeyBinding Key="OemPlus"  Modifiers="Ctrl"       Command="{Binding ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Ctrl"       Command="{Binding ZoomOutCommand}"/>
        <KeyBinding Key="D0"       Modifiers="Ctrl"       Command="{Binding FitToWindowCommand}"/>
        <KeyBinding Key="NumPad0"  Modifiers="Ctrl"       Command="{Binding FitToWindowCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ── Menu Bar ──────────────────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top">

            <MenuItem Header="_File">
                <MenuItem Header="_Open..."
                          Command="{Binding OpenFileCommand}"
                          InputGestureText="Ctrl+O"/>
                <MenuItem Header="Recent _Files"
                          ItemsSource="{Binding RecentFiles}">
                    <MenuItem.ItemContainerStyle>
                        <Style TargetType="MenuItem">
                            <Setter Property="Header"           Value="{Binding}"/>
                            <Setter Property="Command"          Value="{Binding DataContext.OpenRecentFileCommand,
                                                                        RelativeSource={RelativeSource AncestorType=Window}}"/>
                            <Setter Property="CommandParameter" Value="{Binding}"/>
                        </Style>
                    </MenuItem.ItemContainerStyle>
                </MenuItem>
                <Separator/>
                <MenuItem Header="_Print..."
                          Command="{Binding PrintCommand}"
                          InputGestureText="Ctrl+P"/>
                <Separator/>
                <MenuItem Header="E_xit"         Command="{Binding ExitCommand}" InputGestureText="Alt+F4"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Zoom _In"       Command="{Binding ZoomInCommand}"      InputGestureText="Ctrl++"/>
                <MenuItem Header="Zoom _Out"      Command="{Binding ZoomOutCommand}"     InputGestureText="Ctrl+-"/>
                <MenuItem Header="_Fit to Window" Command="{Binding FitToWindowCommand}" InputGestureText="Ctrl+0"/>
                <Separator/>
                <MenuItem Header="Show Page _Borders"
                          IsCheckable="True" IsChecked="{Binding ShowPageBorders}"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="_About PrintShard" Command="{Binding AboutCommand}"/>
            </MenuItem>

        </Menu>

        <!-- ── Status Bar ─────────────────────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom" Padding="4,0">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusFilename}" MaxWidth="220"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding LoadedFilePath}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusImageSize}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusPrinterPaper}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusLayout}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StatusDpi}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main Content ───────────────────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220" MaxWidth="380"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Control Panel ─────────────────────────────────────────────── -->
            <Border Grid.Column="0"
                    BorderBrush="#CCCCCC" BorderThickness="0,0,1,0"
                    Background="{x:Static SystemColors.ControlBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="8,8,8,16">

                        <!-- Open Image -->
                        <Button Content="Open Image..."
                                Command="{Binding OpenFileCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,0,0,8"
                                FontWeight="SemiBold"/>

                        <!-- ── Printer ─────────────────────────────────────── -->
                        <GroupBox Header="Printer">
                            <StackPanel>
                                <ComboBox ItemsSource="{Binding AvailablePrinters}"
                                          SelectedItem="{Binding SelectedPrinterName}"
                                          Margin="0,2"/>
                                <Label Content="Paper Size:" FontSize="11" Foreground="Gray" Margin="0,4,0,0"/>
                                <ComboBox ItemsSource="{Binding AvailablePaperSizes}"
                                          SelectedItem="{Binding SelectedPaperSize}"
                                          Margin="0,2"/>
                                <TextBlock Text="{Binding PaperDimensionsDisplay}"
                                           FontSize="11" Foreground="Gray"
                                           Margin="0,4,0,0"
                                           HorizontalAlignment="Left"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ── Orientation ────────────────────────────────── -->
                        <GroupBox Header="Orientation">
                            <StackPanel>
                                <RadioButton Content="Portrait"
                                             IsChecked="{Binding Orientation,
                                                Converter={StaticResource EnumToBool},
                                                ConverterParameter={x:Static models:PageOrientation.Portrait}}"/>
                                <RadioButton Content="Landscape"
                                             IsChecked="{Binding Orientation,
                                                Converter={StaticResource EnumToBool},
                                                ConverterParameter={x:Static models:PageOrientation.Landscape}}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ── Pages ──────────────────────────────────────── -->
                        <GroupBox Header="Pages">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Label Grid.Row="0" Grid.Column="0" Content="Columns:"/>
                                <controls:NumericSpinner Grid.Row="0" Grid.Column="1"
                                         Value="{Binding PagesWide, Mode=TwoWay}"
                                         Minimum="1" Maximum="20" Increment="1"
                                         StringFormat="F0"
                                         Margin="0,2"/>
                                <TextBlock Grid.Row="0" Grid.Column="2"
                                           Text="⚠" FontSize="14" Foreground="Orange"
                                           VerticalAlignment="Center" Margin="4,0,0,0"
                                           ToolTip="{Binding ExcessPagesWarning}"
                                           Visibility="{Binding HasExcessColumns, Converter={StaticResource BoolToVisibility}}"/>
                                <Label Grid.Row="1" Grid.Column="0" Content="Rows:"/>
                                <controls:NumericSpinner Grid.Row="1" Grid.Column="1"
                                         Value="{Binding PagesTall, Mode=TwoWay}"
                                         Minimum="1" Maximum="20" Increment="1"
                                         StringFormat="F0"
                                         Margin="0,2"/>
                                <TextBlock Grid.Row="1" Grid.Column="2"
                                           Text="⚠" FontSize="14" Foreground="Orange"
                                           VerticalAlignment="Center" Margin="4,0,0,0"
                                           ToolTip="{Binding ExcessPagesWarning}"
                                           Visibility="{Binding HasExcessRows, Converter={StaticResource BoolToVisibility}}"/>
                                <Border Grid.Row="0" Grid.RowSpan="2" Grid.Column="3"
                                        Margin="8,2,0,2" CornerRadius="3"
                                        Background="{StaticResource PagesGridDiagram}"
                                        ToolTip="Pages columns × rows: Number of pages horizontally and vertically"/>
                            </Grid>
                        </GroupBox>

                        <!-- ── Overlap &amp; Margin ───────────────────────── -->
                        <GroupBox>
                            <GroupBox.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Overlap &amp; Margin ("/>
                                    <TextBlock Text="{Binding MeasurementUnit}"/>
                                    <TextBlock Text=")"/>
                                </StackPanel>
                            </GroupBox.Header>
                            <StackPanel>
                                <CheckBox Content="No overlap, default margins"
                                          IsChecked="{Binding NoOverlapDefaultMargins}"
                                          Margin="0,0,0,6"
                                          ToolTip="Sets overlap to 0 and uses default printer margins"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="55"/>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Label Grid.Row="0" Grid.Column="0" Content="Overlap:"/>
                                    <controls:NumericSpinner Grid.Row="0" Grid.Column="1"
                                             Value="{Binding OverlapDisplay, Mode=TwoWay}"
                                             Minimum="0" Maximum="50"
                                             Increment="{Binding OverlapMarginIncrement}"
                                             IsEnabled="{Binding OverlapMarginEnabled}"
                                             Margin="0,2"/>
                                    <Border Grid.Row="0" Grid.Column="2"
                                            Margin="8,2,0,2" CornerRadius="3"
                                            Background="{StaticResource OverlapDiagram}"
                                            ToolTip="Overlap: Extra print area where adjacent pages overlap for easier alignment"/>
                                    <Label Grid.Row="1" Grid.Column="0" Content="Margin:"/>
                                    <controls:NumericSpinner Grid.Row="1" Grid.Column="1"
                                             Value="{Binding MarginDisplay, Mode=TwoWay}"
                                             Minimum="0" Maximum="50"
                                             Increment="{Binding OverlapMarginIncrement}"
                                             IsEnabled="{Binding OverlapMarginEnabled}"
                                             Margin="0,2"/>
                                    <Border Grid.Row="1" Grid.Column="2"
                                            Margin="8,2,0,2" CornerRadius="3"
                                            Background="{StaticResource MarginDiagram}"
                                            ToolTip="Margin: Non-printable border area around each page"/>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- ── Print Order ────────────────────────────────── -->
                        <GroupBox Header="Print Order">
                            <StackPanel>
                                <RadioButton Content="Left to right, row by row"
                                             IsChecked="{Binding PrintOrder,
                                                Converter={StaticResource EnumToBool},
                                                ConverterParameter={x:Static models:PrintOrder.LeftToRightThenDown}}"
                                             Margin="0,0,0,2"/>
                                <RadioButton Content="Top to bottom, column by column"
                                             IsChecked="{Binding PrintOrder,
                                                Converter={StaticResource EnumToBool},
                                                ConverterParameter={x:Static models:PrintOrder.TopToBottomThenRight}}"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ── Crop Marks ──────────────────────────────────── -->
                        <GroupBox Header="Crop Marks">
                            <ComboBox ItemsSource="{Binding CropMarkStyles}"
                                      SelectedItem="{Binding CropMarkStyle}"
                                      Margin="0,2"
                                      ToolTip="Style of crop marks printed on each page">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding}" Value="None">
                                                            <Setter Property="Text" Value="None"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="Corners">
                                                            <Setter Property="Text" Value="Corners"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding}" Value="FullLines">
                                                            <Setter Property="Text" Value="Full lines"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </GroupBox>

                        <!-- ── Print Buttons ──────────────────────────────── -->
                        <Button Content="Print..."
                                Command="{Binding PrintCommand}"
                                HorizontalAlignment="Stretch"
                                Margin="0,12,0,4"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1"
                          Width="4"
                          HorizontalAlignment="Stretch"
                          Background="#DDDDDD"
                          ResizeBehavior="PreviousAndNext"/>

            <!-- ── Preview Canvas ─────────────────────────────────────────── -->
            <controls:ImagePreviewCanvas
                x:Name="PreviewCanvas"
                Grid.Column="2"
                SourceImage="{Binding LoadedImage}"
                Layout="{Binding CurrentLayout}"
                ShowPageBorders="{Binding ShowPageBorders}"
                OverlapColor="{Binding OverlapShadingColorValue}"
                BorderColor="{Binding PageBorderColorValue}"
                FileDrop="PreviewCanvas_FileDrop"/>

        </Grid>
    </DockPanel>
</Window>
