<Window x:Class="PrintShard.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About PrintShard"
        Width="380"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <DockPanel>
        <!-- App icon on the left -->
        <Image Source="/Assets/icon.ico"
               Width="64"
               Height="64"
               VerticalAlignment="Center"
               Margin="20,20,16,20"/>

        <!-- Text content on the right -->
        <StackPanel VerticalAlignment="Center"
                    Margin="0,20,20,20">
            <TextBlock Text="PrintShard"
                       FontSize="18"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>

            <TextBlock x:Name="VersionText"
                       FontSize="12"
                       Margin="0,0,0,10"/>

            <TextBlock Text="Large-format tile printing&#x0a;&#x0a;Print any image across multiple pages."
                       TextWrapping="Wrap"/>
        </StackPanel>
    </DockPanel>
</Window>
