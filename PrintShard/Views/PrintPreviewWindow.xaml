<Window x:Class="PrintShard.Views.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Print Preview — PrintShard"
        Height="650" Width="600"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="{Binding CloseCommand}"/>
        <KeyBinding Key="Left"   Command="{Binding PreviousPageCommand}"/>
        <KeyBinding Key="Right"  Command="{Binding NextPageCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Page Preview ───────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="#555555">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Image Source="{Binding CurrentPageBitmap}"
                       Margin="20"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="HighQuality">
                    <Image.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.5"
                                          ShadowDepth="4" Direction="315"/>
                    </Image.Effect>
                </Image>
            </ScrollViewer>
        </Border>

        <!-- ── Navigation Bar ────────────────────────────────────────────── -->
        <Border Grid.Row="1"
                BorderThickness="0,1,0,0" BorderBrush="#CCCCCC"
                Background="{x:Static SystemColors.ControlBrush}"
                Padding="8,6">
            <DockPanel>
                <!-- Print button on the right -->
                <Button DockPanel.Dock="Right"
                        Content="Print..."
                        Command="{Binding PrintCommand}"
                        Width="90" Margin="8,0,0,0"/>
                <Button DockPanel.Dock="Right"
                        Content="Close"
                        Command="{Binding CloseCommand}"
                        Width="70"/>

                <!-- Navigation in the center -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Button Content="◀ Previous"
                            Command="{Binding PreviousPageCommand}"
                            Width="90" Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PageLabel}"
                               VerticalAlignment="Center"
                               FontSize="13"
                               MinWidth="100"
                               TextAlignment="Center"/>
                    <Button Content="Next ▶"
                            Command="{Binding NextPageCommand}"
                            Width="90" Margin="8,0,0,0"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
